            saveUserFactionId();

            // Save enemy ID
            const enemyInput = modal.querySelector('#tt-enemy-id');
            const newEnemyId = enemyInput.value.trim();
            if (newEnemyId && !isNaN(parseInt(newEnemyId, 10))) {
                enemyFactionId = parseInt(newEnemyId, 10);
            } else {
                enemyFactionId = null;
            }
            saveEnemyId();

            // Update both buttons
            updateHomeButtonHref();
            updateEnemyButtonHref();

            renderQuickUseButtons();
            closeSettingsModal();
        });
