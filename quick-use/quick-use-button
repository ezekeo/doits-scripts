    // ------------------------------------------------------------------
    // SHORTCUT HANDLING
    // ------------------------------------------------------------------
    function formatKeyEvent(e) {
        const parts = [];
        if (e.ctrlKey) parts.push('Ctrl');
        if (e.altKey) parts.push('Alt');
        if (e.shiftKey) parts.push('Shift');
        if (e.metaKey) parts.push('Meta');
        const key = e.key.length === 1 ? e.key.toUpperCase() : e.key;
        if (key && !['Control', 'Alt', 'Shift', 'Meta'].includes(key)) {
            parts.push(key);
        }
        return parts.join('+');
    }

    function handleShortcutKeydown(e) {
        if (activeShortcutInput) {
            e.preventDefault();
            const shortcut = formatKeyEvent(e);
            if (shortcut) {
                activeShortcutInput.value = shortcut;
                const id = activeShortcutInput.dataset.id;
                if (id) {
                    shortcuts[id] = shortcut;
                    saveShortcuts();
                }
            }
            activeShortcutInput = null;
        } else {
            const active = document.activeElement;
            if (active && (active.tagName === 'INPUT' || active.tagName === 'TEXTAREA' || active.isContentEditable)) {
                return;
            }
            const pressed = formatKeyEvent(e);
            if (!pressed) return;
            for (const [idStr, shortcut] of Object.entries(shortcuts)) {
                if (shortcut === pressed) {
                    const itemId = parseInt(idStr, 10);
                    if (!enabledItemIds.includes(itemId)) continue;
                    if (availableItemIds.length && !availableItemIds.includes(itemId)) continue;
                    const btn = document.querySelector(`.tt-quickuse-btn[data-item-id="${itemId}"]`);
                    if (btn && !btn.disabled) {
                        btn.click();
                        e.preventDefault();
                    }
                    break;
                }
            }
        }
    }

