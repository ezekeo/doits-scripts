        // Helper to rebuild the items list with remove buttons
        function rebuildItemsList() {
            const container = modal.querySelector('#tt-quickuse-items-container');
            container.innerHTML = '';

            if (availableItemIds.length === 0) {
                container.innerHTML = '<div class="tt-no-items">No items scanned. Click "Scan Armoury" first.</div>';
                return;
            }

            const availableItems = ALL_ITEMS.filter(item => availableItemIds.includes(item.id));
            // Group by category
            const grouped = {};
            for (const item of availableItems) {
                if (!grouped[item.category]) grouped[item.category] = [];
                grouped[item.category].push(item);
            }

            if (isMobile()) {
                // Mobile: flat list with category headers, selectable rows, and remove button
                for (const cat of CATEGORIES) {
                    const items = grouped[cat];
                    if (!items || items.length === 0) continue;

                    const header = document.createElement('div');
                    header.className = 'tt-category-header';
                    header.textContent = `${cat} (${items.length})`;
                    container.appendChild(header);

                    items.forEach(item => {
                        const row = document.createElement('div');
                        row.className = 'tt-item-row';
                        row.dataset.id = item.id;
                        if (enabledItemIds.includes(item.id)) row.classList.add('selected');
                        row.innerHTML = `
                            <span class="tt-item-name">${item.name}</span>
                            <span class="tt-item-check">✓</span>
                            <button class="tt-remove-item" data-id="${item.id}" title="Remove from scanned items">✖</button>
                        `;
                        row.addEventListener('click', (e) => {
                            if (!e.target.classList.contains('tt-remove-item')) {
                                row.classList.toggle('selected');
                            }
                        });
                        const removeBtn = row.querySelector('.tt-remove-item');
                        removeBtn.addEventListener('click', (e) => {
                            e.stopPropagation();
                            const id = parseInt(removeBtn.dataset.id, 10);
                            // Remove from availableItemIds
                            const index = availableItemIds.indexOf(id);
                            if (index !== -1) availableItemIds.splice(index, 1);
                            // Also remove from enabledItemIds if present
                            const enabledIndex = enabledItemIds.indexOf(id);
                            if (enabledIndex !== -1) enabledItemIds.splice(enabledIndex, 1);
                            saveAvailableCache();
                            saveEnabled();
                            rebuildItemsList(); // refresh UI
                            renderQuickUseButtons(); // update main panel
                        });
                        container.appendChild(row);
                    });
                }
            } else {
                // Desktop: cards with checkboxes, shortcut inputs, and remove button
                for (const cat of CATEGORIES) {
                    const items = grouped[cat];
                    if (!items || items.length === 0) continue;

                    const card = document.createElement('div');
                    card.className = 'tt-category-card';
                    card.innerHTML = `
                        <div class="tt-category-title">${cat}</div>
                        <div class="tt-items-grid"></div>
                    `;
                    const grid = card.querySelector('.tt-items-grid');
                    items.forEach(item => {
                        const itemDiv = document.createElement('div');
                        itemDiv.className = 'tt-desktop-item';
                        const checkbox = document.createElement('input');
                        checkbox.type = 'checkbox';
                        checkbox.className = 'tt-item-checkbox';
                        checkbox.value = item.id;
                        checkbox.checked = enabledItemIds.includes(item.id);
                        const nameSpan = document.createElement('span');
                        nameSpan.className = 'tt-item-name';
                        nameSpan.textContent = item.name;
                        const shortcutInput = document.createElement('input');
                        shortcutInput.type = 'text';
                        shortcutInput.placeholder = 'Shortcut';
                        shortcutInput.className = 'tt-shortcut-input';
                        shortcutInput.value = shortcuts[item.id] || '';
                        shortcutInput.dataset.id = item.id;
                        shortcutInput.addEventListener('focus', () => {
                            activeShortcutInput = shortcutInput;
                            shortcutInput.placeholder = 'Press keys...';
                        });
                        shortcutInput.addEventListener('blur', () => {
                            if (activeShortcutInput === shortcutInput) activeShortcutInput = null;
                            shortcutInput.placeholder = 'Shortcut';
                        });
                        const removeBtn = document.createElement('button');
                        removeBtn.textContent = '✖';
                        removeBtn.className = 'tt-remove-item';
                        removeBtn.title = 'Remove from scanned items';
                        removeBtn.addEventListener('click', () => {
                            const id = item.id;
                            const index = availableItemIds.indexOf(id);
                            if (index !== -1) availableItemIds.splice(index, 1);
                            const enabledIndex = enabledItemIds.indexOf(id);
                            if (enabledIndex !== -1) enabledItemIds.splice(enabledIndex, 1);
                            saveAvailableCache();
                            saveEnabled();
                            rebuildItemsList();
                            renderQuickUseButtons();
                        });
                        itemDiv.appendChild(checkbox);
                        itemDiv.appendChild(nameSpan);
                        itemDiv.appendChild(shortcutInput);
                        itemDiv.appendChild(removeBtn);
                        grid.appendChild(itemDiv);
                    });
                    container.appendChild(card);
                }
            }
        }

        settingsModal.__rebuild = rebuildItemsList;
        rebuildItemsList();
    }

