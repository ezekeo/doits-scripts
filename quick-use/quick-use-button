                setTimeout(() => { scanStatus.textContent = ''; }, 4000);
            } finally {
                scanBtn.disabled = false;
            }
        });

        // Detect factions button
        const detectBtn = modal.querySelector('#tt-detect-factions');
        detectBtn.addEventListener('click', () => {
            detectFactionsFromCurrentPage();
            // Update input fields with new values
            const userInput = modal.querySelector('#tt-user-id');
            if (userInput) userInput.value = userFactionId || '';
            const enemyInput = modal.querySelector('#tt-enemy-id');
            if (enemyInput) enemyInput.value = enemyFactionId || '';
        });

        // Reset button
        const resetBtn = modal.querySelector('#tt-reset');
        resetBtn.addEventListener('click', () => {
            if (confirm('⚠️ This will delete all your saved items, shortcuts, and faction IDs. Are you sure?')) {
                resetAll();
            }
        });

        // Save and Cancel
        modal.querySelector('#tt-save').addEventListener('click', () => {
            if (isMobile()) {
                // Mobile: read selected items from wheel rows
                const selectedRows = modal.querySelectorAll('.tt-item-row.selected');
                enabledItemIds = Array.from(selectedRows).map(row => parseInt(row.dataset.id, 10));
            } else {
                // Desktop: read from checkboxes
                enabledItemIds = [];
                modal.querySelectorAll('.tt-item-checkbox').forEach(cb => {
                    if (cb.checked) enabledItemIds.push(parseInt(cb.value, 10));
                });
                // Save shortcuts
                const shortcutInputs = modal.querySelectorAll('.tt-shortcut-input');
                shortcutInputs.forEach(inp => {
                    const id = parseInt(inp.dataset.id, 10);
                    if (inp.value) shortcuts[id] = inp.value;
                    else delete shortcuts[id];
                });
                saveShortcuts();
            }
            saveEnabled();

            // Save user faction ID
            const userInput = modal.querySelector('#tt-user-id');
            const newUserId = userInput.value.trim();
            if (newUserId && !isNaN(parseInt(newUserId, 10))) {
                userFactionId = parseInt(newUserId, 10);
            } else {
                userFactionId = null;
