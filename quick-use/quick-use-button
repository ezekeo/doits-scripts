    function enableOutsideClose() {
        document.addEventListener("click", (e) => {
            if (!quickUsePanel) return;
            // Close panel if click outside both panel and FAB
            if (!quickUsePanel.contains(e.target) && !roundButton.contains(e.target)) {
                quickUsePanel.classList.remove("open");
            }
            // Close settings modal if click outside it
            if (settingsModal && settingsModal.style.display === 'block') {
                if (!settingsModal.contains(e.target) && !roundButton.contains(e.target)) {
                    closeSettingsModal();
                }
            }
        });
    }

