    // ------------------------------------------------------------------
    // FACTION DETECTION (manual)
    // ------------------------------------------------------------------
    function detectFactionsFromCurrentPage() {
        // Check if we are on a faction page
        const isFactionPage = window.location.href.includes('factions.php') &&
                              window.location.href.includes('step=profile');
        if (!isFactionPage) {
            alert('Please navigate to your faction profile page first.\n(e.g., https://www.torn.com/factions.php?step=profile&ID=xxxxx)');
            return false;
        }

        // Try to find the faction ID from URL
        const urlMatch = window.location.href.match(/ID=(\d+)/);
        let detectedUserFaction = null;
        if (urlMatch && urlMatch[1]) {
            detectedUserFaction = parseInt(urlMatch[1], 10);
        }

        // Look for enemy faction link on the page (if in war)
        let detectedEnemy = null;
        // Common selectors for war opponent
        const enemyLinks = document.querySelectorAll('a[href*="factions.php?step=profile&ID="]');
        for (let link of enemyLinks) {
            const href = link.getAttribute('href');
            const match = href.match(/ID=(\d+)/);
            if (match && match[1]) {
                const id = parseInt(match[1], 10);
                // If we have a user faction and it's different, it's likely the enemy
                if (detectedUserFaction && id !== detectedUserFaction) {
                    detectedEnemy = id;
                    break;
                }
                // If no user faction yet, take the first one we find (maybe)
                if (!detectedUserFaction && !detectedEnemy) {
                    detectedEnemy = id;
                }
            }
        }

        // Also look for the war panel specifically
        const warContainer = document.querySelector('.war-report, .war-container, [class*="war"]');
        if (warContainer) {
            const warLink = warContainer.querySelector('a[href*="factions.php?step=profile&ID="]');
            if (warLink) {
                const match = warLink.getAttribute('href').match(/ID=(\d+)/);
                if (match && match[1]) {
                    detectedEnemy = parseInt(match[1], 10);
                }
            }
        }

        if (detectedUserFaction) {
            userFactionId = detectedUserFaction;
            saveUserFactionId();
            updateHomeButtonHref();
        }
        if (detectedEnemy) {
            enemyFactionId = detectedEnemy;
            saveEnemyId();
            updateEnemyButtonHref();
        }

        let message = '';
        if (detectedUserFaction) message += `Your faction: ${detectedUserFaction}. `;
        if (detectedEnemy) message += `Enemy faction: ${detectedEnemy}. `;
        if (!detectedUserFaction && !detectedEnemy) message = 'Could not detect any faction IDs.';
        alert(message);
        return true;
    }

    // ------------------------------------------------------------------
    // ARMOURY SCANNER
    // ------------------------------------------------------------------
    function scanArmoury() {
        const url = window.location.href;
        const isFactionsPage = url.includes('factions.php');
        const hasArmouryHash = url.includes('#/tab=armoury');
        if (!isFactionsPage || !hasArmouryHash) {
            throw new Error('Not on armoury page. Go to Factions > Armoury first.');
        }

        const itemElements = document.querySelectorAll('.img-wrap[data-itemid]');
        if (itemElements.length === 0) {
            throw new Error('No items found. Make sure you are on a visible armoury tab (e.g., Medical, Drugs, etc.).');
        }

        const found = new Set();
        for (const el of itemElements) {
            const id = parseInt(el.getAttribute('data-itemid'), 10);
            if (id && ALL_ITEMS.some(i => i.id === id)) {
                found.add(id);
            }
        }
        if (found.size === 0) throw new Error('No recognized items found.');
        return Array.from(found);
    }

    // ------------------------------------------------------------------
    // ITEM USAGE
    // ------------------------------------------------------------------
    function getCsrfToken() {
        const meta = document.querySelector('meta[name="csrf-token"]');
        if (meta && meta.getAttribute('content')) return meta.getAttribute('content');
        const input = document.querySelector('input[name="csrf_token"]');
        if (input && input.value) return input.value;
        if (window.csrfToken) return window.csrfToken;
        return null;
    }

    async function useItem(itemID) {
        const url = '/item.php';
        const params = new URLSearchParams();
        params.set('step', 'useItem');
        params.set('fac', '1');
        params.set('itemID', itemID.toString());
        const csrf = getCsrfToken();
        if (csrf) params.set('csrf_token', csrf);

        const headers = {
            'Content-Type': 'application/x-www-form-urlencoded',
            'X-Requested-With': 'XMLHttpRequest',
            'Accept': 'application/json, text/javascript, */*; q=0.01'
        };
        const response = await fetch(url, {
            method: 'POST',
            headers: headers,
            body: params,
            credentials: 'include',
            referrerPolicy: 'same-origin'
        });
        if (!response.ok) throw new Error(`HTTP ${response.status}: ${response.statusText}`);
        const rawText = await response.text();
        try {
            return JSON.parse(rawText);
        } catch (e) {
            throw new Error(`Invalid JSON response. Raw: ${rawText.substring(0, 200)}`);
        }
    }

    function setStatus(text, isError = false) {
        const statusDiv = document.getElementById('tt-quickuse-status');
        if (statusDiv) {
            const cleanText = text.replace(/<[^>]*>/g, '');
            statusDiv.textContent = cleanText;
            statusDiv.style.color = isError ? '#ff8888' : '#88ff88';
            if (!isError) {
                setTimeout(() => {
                    if (statusDiv.textContent === cleanText) {
                        statusDiv.textContent = 'Ready.';
                        statusDiv.style.color = '#cccccc';
                    }
                }, 5000);
            }
        }
    }

    // ------------------------------------------------------------------
    // RENDER MAIN BUTTONS
    // ------------------------------------------------------------------
    function renderQuickUseButtons() {
        if (!currentButtonsGrid) return;
        currentButtonsGrid.innerHTML = '';

        let itemsToShow = ALL_ITEMS.filter(item => enabledItemIds.includes(item.id));
        if (availableItemIds.length) {
            itemsToShow = itemsToShow.filter(item => availableItemIds.includes(item.id));
        }

        if (itemsToShow.length === 0) {
            const msg = document.createElement('div');
            msg.textContent = availableItemIds.length
                ? 'No enabled items found.'
                : 'No items scanned. Right‑click the round button and click "Scan Armoury".';
            msg.style.textAlign = 'center';
            msg.style.padding = '12px';
            msg.style.color = '#aaaaaa';
            msg.style.gridColumn = '1 / -1';
            currentButtonsGrid.appendChild(msg);
            return;
        }

        itemsToShow.forEach(item => {
            const btn = document.createElement('button');
            btn.className = 'tt-quickuse-btn';
            if (item.category === 'Drug') btn.classList.add('drug-btn');
            btn.textContent = item.name;
            btn.dataset.itemId = item.id;
            btn.dataset.itemName = item.name;
            currentButtonsGrid.appendChild(btn);
        });
        attachButtonHandlers();
    }

    function attachButtonHandlers() {
        const buttons = document.querySelectorAll('.tt-quickuse-btn');
        const cooldownMap = new Map();
        buttons.forEach(btn => {
            const itemId = parseInt(btn.dataset.itemId, 10);
            const itemName = btn.dataset.itemName;
            btn.removeEventListener('click', handleClick);
            btn.addEventListener('click', handleClick);
            async function handleClick(e) {
                const now = Date.now();
                const lastClick = cooldownMap.get(itemId) || 0;
                if (now - lastClick < CLICK_COOLDOWN_MS) {
                    setStatus(`Please wait before using another ${itemName}.`, true);
                    return;
                }
                cooldownMap.set(itemId, now);
                btn.disabled = true;
                setStatus(`Using ${itemName}...`);
                try {
                    const result = await useItem(itemId);
                    if (result.success === true) {
                        setStatus(result.message || `${itemName} used successfully.`);
                    }
                    else if (result.success === false) {
                        const errorMsg = result.text || result.error || 'Unknown error';
                        setStatus(errorMsg, true);
                    }
                    else if (result.error) {
                        setStatus(result.error, true);
                    }
                    else if (result.message) {
                        setStatus(result.message);
                    }
                    else {
                        setStatus(JSON.stringify(result), true);
                    }
                } catch (error) {
                    console.error('QuickUse error:', error);
                    setStatus(`Error: ${error.message}`, true);
                } finally {
                    setTimeout(() => { btn.disabled = false; }, CLICK_COOLDOWN_MS);
                }
            }
        });
    }

